NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb://localhost:27017/fco-hub
CLIENT_URL=http://localhost:5173
ENABLE_BACKGROUND_SYNC=false
NEXON_METADATA_SYNC_CRON=0 4 * * *
FIFAADDICT_SYNC_CRON=*/30 * * * *

# Cloudinary configuration: use either CLOUDINARY_URL or the split variables below.
# CLOUDINARY_URL=cloudinary://<api-key>:<api-secret>@<cloud-name>
# CLOUDINARY_CLOUD_NAME=<cloud-name>
# CLOUDINARY_API_KEY=<api-key>
# CLOUDINARY_API_SECRET=<api-secret>

# Admin asset uploads default to 10 MiB when omitted.
ASSET_UPLOAD_MAX_BYTES=10485760
